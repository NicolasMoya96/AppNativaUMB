<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="#D32F2F"
        android:padding="10dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/volver"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#B71C1C"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            app:cornerRadius="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/formulario_titulo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@android:color/white"
        android:layout_margin="15dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/formulario_datos"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#C62828"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <EditText
            android:id="@+id/editTextNombre"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/formulario_nombre_hint"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="15dp"
            android:inputType="textPersonName"
            android:autofillHints="name"
            android:textColor="@android:color/black"
            android:textColorHint="#757575"/>

        <EditText
            android:id="@+id/editTextApellido"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/formulario_apellido_hint"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="15dp"
            android:inputType="textPersonName"
            android:autofillHints="name"
            android:textColor="@android:color/black"
            android:textColorHint="#757575"/>

        <EditText
            android:id="@+id/editTextEdad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/formulario_edad_hint"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="25dp"
            android:inputType="number"
            android:autofillHints="age"
            android:textColor="@android:color/black"
            android:textColorHint="#757575"/>

        <Button
            android:id="@+id/btnEnviar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/guardar_datos"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#C62828"
            android:minWidth="48dp"
            android:minHeight="48dp"
            app:cornerRadius="12dp"/>

    </LinearLayout>

</LinearLayout>