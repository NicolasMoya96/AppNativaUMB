<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="0dp">

    <!-- Barra superior - aumentado tamaño para mejor touch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:background="#9C27B0"
        android:padding="10dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/volver"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#6A1B9A"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            app:cornerRadius="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/agenda_titulo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Formulario -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp"
        android:background="@android:color/white"
        android:layout_margin="15dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/agenda_nueva"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#9C27B0"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/editTextFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/agenda_fecha_hint"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="10dp"
            android:inputType="date"
            android:autofillHints="date"
            android:textColor="@android:color/black"
            android:textColorHint="#757575"
            android:minHeight="48dp"/>

        <EditText
            android:id="@+id/editTextAsunto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/agenda_asunto_hint"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="10dp"
            android:inputType="text"
            android:autofillHints="subject"
            android:textColor="@android:color/black"
            android:textColorHint="#757575"
            android:minHeight="48dp"/>

        <EditText
            android:id="@+id/editTextActividad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/agenda_actividad_hint"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="20dp"
            android:inputType="text"
            android:autofillHints="activity"
            android:textColor="@android:color/black"
            android:textColorHint="#757575"
            android:minHeight="48dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            style="?android:attr/buttonBarStyle">

            <Button
                android:id="@+id/btnAgregar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/agregar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#9C27B0"
                android:layout_marginEnd="5dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                style="?android:attr/buttonBarButtonStyle"
                app:cornerRadius="8dp"/>

            <Button
                android:id="@+id/btnConsultar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/consultar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#7B1FA2"
                android:layout_marginStart="5dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                style="?android:attr/buttonBarButtonStyle"
                app:cornerRadius="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ListView -->
    <ListView
        android:id="@+id/listViewAgenda"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="15dp"
        android:layout_marginTop="0dp"
        android:background="@android:color/white"
        android:padding="10dp"
        android:elevation="2dp"/>

</LinearLayout>