<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/menu_principal"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#C62828"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif-black"/>

    <!-- Línea decorativa -->
    <View
        android:layout_width="80dp"
        android:layout_height="4dp"
        android:background="#C62828"
        android:layout_gravity="center"
        android:layout_marginBottom="40dp"/>

    <!-- Botón 1: Página UMB -->
    <Button
        android:id="@+id/btnPaginaUMB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:minWidth="48dp"
        android:text="@string/btn_pagina_umb"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#C62828"
        android:layout_marginBottom="15dp"
        android:padding="10dp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="12dp"/>

    <!-- Botón 2: Buscador Web -->
    <Button
        android:id="@+id/btnBuscadorWeb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:minWidth="48dp"
        android:text="@string/btn_buscador_web"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#EF5350"
        android:layout_marginBottom="15dp"
        android:padding="10dp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="12dp"/>

    <!-- Botón 3: Formulario Estudiante -->
    <Button
        android:id="@+id/btnMensajes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:minWidth="48dp"
        android:text="@string/btn_formulario"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#D32F2F"
        android:layout_marginBottom="15dp"
        android:padding="10dp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="12dp"/>

    <!-- Botón 4: AGENDA SQLite (NUEVO) -->
    <Button
        android:id="@+id/btnAgenda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:minWidth="48dp"
        android:text="@string/btn_agenda"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#9C27B0"
        android:layout_marginBottom="15dp"
        android:padding="10dp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="12dp"/>

    <!-- Espacio flexible -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Botón 5: CERRAR SESIÓN -->
    <Button
        android:id="@+id/btnSalir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:minWidth="48dp"
        android:text="@string/btn_salir"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#424242"
        android:padding="10dp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="12dp"/>

</LinearLayout>